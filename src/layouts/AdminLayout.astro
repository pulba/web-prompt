---
import Sidebar from '@/components/layout/Sidebar.astro';
import Header from '@/components/layout/Header.astro';
import MobileNav from '@/components/layout/MobileNav.astro';
import '@/styles/globals.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Prompt Vault Admin</title>
		<script is:inline>
			const theme = (() => {
				const stored = typeof localStorage !== 'undefined' && localStorage.getItem('theme');
				if (stored && stored !== 'system') return stored;
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
				return 'light';
			})();
			document.documentElement.classList.toggle('dark', theme === 'dark');
		</script>
	</head>
	<body class="bg-surface-bg text-gray-900 dark:bg-dark-bg dark:text-gray-100 antialiased transition-colors duration-200">
		<div class="flex min-h-screen overflow-hidden">
			<!-- Desktop Sidebar -->
			<aside class="hidden md:flex md:w-64 md:flex-col fixed inset-y-0">
				<Sidebar />
			</aside>

			<!-- Main Content -->
			<div class="flex flex-col flex-1 md:pl-64">
				<Header />
				
				<main class="flex-1 overflow-y-auto p-4 md:p-8">
					<div class="max-w-7xl mx-auto">
						<slot />
					</div>
				</main>
				
				<MobileNav />
			</div>
		</div>
	</body>
</html>
