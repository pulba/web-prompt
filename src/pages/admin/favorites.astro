---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { promptService } from '@/lib/prompts/service';

const prompts = await promptService.getFavorites();
---

<AdminLayout title="Favorite Prompts">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">Favorite Prompts</h1>
    </div>

    <div class="bg-surface-card dark:bg-dark-card border border-surface-border dark:border-dark-border rounded-2xl overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800/50 border-b border-surface-border dark:border-dark-border">
            <th class="px-6 py-4 text-sm font-semibold">Title & Tags</th>
            <th class="px-6 py-4 text-sm font-semibold">Category</th>
            <th class="px-6 py-4 text-sm font-semibold text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-border dark:divide-dark-border">
          {prompts.length === 0 ? (
            <tr>
              <td colspan="3" class="px-6 py-8 text-center text-gray-500">No favorite prompts found.</td>
            </tr>
          ) : (
            prompts.map((p) => (
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-medium">{p.title}</p>
                  <div class="flex flex-wrap gap-1 mt-1">
                    {p.tags?.map(t => (
                      <span class="text-[10px] px-1.5 py-0.5 bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 rounded-md">
                        #{t.name}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">
                  {p.category_name || <span class="italic text-gray-400">Uncategorized</span>}
                </td>
                <td class="px-6 py-4 text-right space-x-2">
                  <button class="text-yellow-500 hover:text-gray-400 transition-colors" data-favorite={p.id}>
                    ★
                  </button>
                  <a href={`/admin/prompts/${p.id}/edit`} class="text-brand-primary hover:underline text-sm font-medium">Edit</a>
                  <button class="text-red-500 hover:underline text-sm font-medium" data-delete={p.id}>Delete</button>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  // Simple favorite toggle handler
  document.querySelectorAll('[data-favorite]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.favorite;
      const res = await fetch(`/api/prompts/${id}`, { 
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ toggleFavorite: true })
      });
      const result = await res.json();
      if (result.success) window.location.reload();
      else alert(result.error || 'Failed to toggle favorite');
    });
  });

  // Simple delete handler
  document.querySelectorAll('[data-delete]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      if (!confirm('Are you sure?')) return;
      const id = (e.currentTarget as HTMLElement).dataset.delete;
      const res = await fetch(`/api/prompts/${id}`, { method: 'DELETE' });
      const result = await res.json();
      if (result.success) window.location.reload();
      else alert(result.error || 'Failed to delete');
    });
  });
</script>
