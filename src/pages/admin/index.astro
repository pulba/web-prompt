---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { dbClient } from '@/lib/db';
import { promptService } from '@/lib/prompts/service';

// 1. Fetch stats count dynamically
const [promptsCountRes, categoriesCountRes, tagsCountRes, favoritesCountRes] = await Promise.all([
  dbClient.execute('SELECT COUNT(*) as count FROM prompts'),
  dbClient.execute('SELECT COUNT(*) as count FROM categories'),
  dbClient.execute('SELECT COUNT(*) as count FROM tags'),
  dbClient.execute('SELECT COUNT(*) as count FROM prompts WHERE favorite = 1'),
]);

const promptsCount = Number(promptsCountRes.rows[0].count);
const categoriesCount = Number(categoriesCountRes.rows[0].count);
const tagsCount = Number(tagsCountRes.rows[0].count);
const favoritesCount = Number(favoritesCountRes.rows[0].count);

const stats = [
  { label: 'Total Prompts', value: promptsCount.toString(), icon: 'terminal' },
  { label: 'Categories', value: categoriesCount.toString(), icon: 'folder' },
  { label: 'Tags', value: tagsCount.toString(), icon: 'tag' },
  { label: 'Favorites', value: favoritesCount.toString(), icon: 'star' },
];

// 2. Fetch the 3 most recent prompts
const recentPrompts = await promptService.getAllPrompts();
const displayRecentPrompts = recentPrompts.slice(0, 3);
---

<AdminLayout title="Dashboard">
  <div class="space-y-8">
    <!-- Welcome Header -->
    <div>
      <h1 class="text-2xl font-bold md:text-3xl">Welcome back, Admin</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">Here's what's happening with your prompt vault.</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {stats.map((stat) => (
        <div class="p-6 bg-surface-card dark:bg-dark-card border border-surface-border dark:border-dark-border rounded-2xl shadow-sm">
          <p class="text-sm font-medium text-gray-500 dark:text-gray-400">{stat.label}</p>
          <p class="text-2xl font-bold mt-2">{stat.value}</p>
        </div>
      ))}
    </div>

    <!-- Recent Prompts -->
    <div class="bg-surface-card dark:bg-dark-card border border-surface-border dark:border-dark-border rounded-2xl p-6">
      <h2 class="text-lg font-bold mb-4">Recent Prompts</h2>
      <div class="space-y-4">
        {displayRecentPrompts.length === 0 ? (
          <p class="text-center py-6 text-gray-500 text-sm">No prompts found.</p>
        ) : (
          displayRecentPrompts.map((p) => (
            <div class="flex items-center justify-between p-4 bg-surface-bg dark:bg-dark-bg rounded-xl border border-surface-border dark:border-dark-border">
              <div class="flex items-center space-x-4">
                <div class="w-10 h-10 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                  <span class="text-base text-brand-primary">⚡</span>
                </div>
                <div>
                  <p class="font-medium">{p.title}</p>
                  <p class="text-xs text-gray-500">
                    Added on {new Date(p.created_at).toLocaleDateString('id-ID', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric',
                    })}
                  </p>
                </div>
              </div>
              <a href={`/admin/prompts/${p.id}/edit`} class="text-brand-primary text-sm font-medium hover:underline">
                Edit
              </a>
            </div>
          ))
        )}
      </div>
    </div>
  </div>
</AdminLayout>
