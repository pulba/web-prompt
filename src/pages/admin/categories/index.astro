---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { categoryService } from '@/lib/categories/service';

const categories = await categoryService.getAllCategories();
---

<AdminLayout title="Manage Categories">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">Categories</h1>
      <a href="/admin/categories/new" class="px-4 py-2 bg-brand-primary text-white rounded-xl font-medium hover:opacity-90 transition-opacity">
        Add New Category
      </a>
    </div>

    <div class="bg-surface-card dark:bg-dark-card border border-surface-border dark:border-dark-border rounded-2xl overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800/50 border-b border-surface-border dark:border-dark-border">
            <th class="px-6 py-4 text-sm font-semibold">Name</th>
            <th class="px-6 py-4 text-sm font-semibold text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-border dark:divide-dark-border">
          {categories.length === 0 ? (
            <tr>
              <td colspan="2" class="px-6 py-8 text-center text-gray-500">No categories found.</td>
            </tr>
          ) : (
            categories.map((c) => (
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition-colors">
                <td class="px-6 py-4">
                  <p class="font-medium">{c.name}</p>
                </td>
                <td class="px-6 py-4 text-right space-x-2">
                  <a href={`/admin/categories/${c.id}/edit`} class="text-brand-primary hover:underline text-sm font-medium">Edit</a>
                  <button class="text-red-500 hover:underline text-sm font-medium" data-delete={c.id}>Delete</button>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll('[data-delete]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      if (!confirm('Hapus kategori ini? Prompt yang menggunakan kategori ini akan menjadi Uncategorized.')) return;
      const id = (e.currentTarget as HTMLElement).dataset.delete;
      const res = await fetch(`/api/categories/${id}`, { method: 'DELETE' });
      const result = await res.json();
      if (result.success) window.location.reload();
      else alert(result.error || 'Gagal menghapus kategori');
    });
  });
</script>
