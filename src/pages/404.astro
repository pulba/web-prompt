---
import MainLayout from '@/layouts/MainLayout.astro';
---

<MainLayout title="404 - Page Not Found">
  <div class="flex flex-col items-center justify-center py-20 text-center space-y-6">
    <h1 class="text-9xl font-extrabold text-brand-primary">404</h1>
    <div class="space-y-2">
      <h2 class="text-3xl font-bold">Page Not Found</h2>
      <p class="text-gray-500 max-w-md mx-auto">
        The page you are looking for doesn't exist or has been moved.
      </p>
    </div>
    <a href="/" class="px-8 py-3 bg-brand-primary text-white rounded-2xl font-bold hover:opacity-90 transition-opacity">
      Back to Home
    </a>
  </div>
</MainLayout>
