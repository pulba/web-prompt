---
import type { PromptWithRelations } from '@/lib/prompts/repository';

interface Props {
  prompt: PromptWithRelations;
}

const { prompt } = Astro.props;
---

<div class="p-6 bg-surface-card dark:bg-dark-card border border-surface-border dark:border-dark-border rounded-2xl shadow-sm hover:shadow-md transition-all group relative">
  <div class="flex justify-between items-start mb-4">
    <div>
      <a href={`/categories/${prompt.category_id}`} class="text-[10px] font-bold uppercase tracking-wider text-brand-primary hover:underline mb-1 block">
        {prompt.category_name || 'Uncategorized'}
      </a>
      <h3 class="text-lg font-bold leading-tight group-hover:text-brand-primary transition-colors">
        <a href={`/prompts/${prompt.id}`}>{prompt.title}</a>
      </h3>
    </div>
    <span class={`text-xl ${prompt.favorite ? 'text-yellow-500' : 'text-gray-300'}`}>
      {prompt.favorite ? '★' : '☆'}
    </span>
  </div>
  
  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-6">
    {prompt.content}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {prompt.tags?.map(t => (
      <a href={`/tags/${t.id}`} class="text-[10px] px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-md hover:bg-brand-primary hover:text-white transition-colors">
        #{t.name}
      </a>
    ))}
  </div>
  
  <div class="mt-6 pt-4 border-t border-surface-border dark:border-dark-border flex justify-between items-center">
    <span class="text-[10px] text-gray-400">{new Date(prompt.created_at).toLocaleDateString()}</span>
    <button 
      class="text-xs font-bold text-brand-primary hover:underline copy-btn" 
      data-content={prompt.content}
    >
      Copy Prompt
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const content = (e.currentTarget as HTMLElement).dataset.content;
      if (content) {
        navigator.clipboard.writeText(content);
        const originalText = (e.currentTarget as HTMLElement).innerText;
        (e.currentTarget as HTMLElement).innerText = 'Copied!';
        setTimeout(() => {
          (e.currentTarget as HTMLElement).innerText = originalText;
        }, 2000);
      }
    });
  });
</script>
