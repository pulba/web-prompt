---
import ThemeToggle from '@/components/ui/ThemeToggle.astro';
---

<header class="sticky top-0 z-10 flex items-center h-16 px-4 bg-surface-bg/80 dark:bg-dark-bg/80 backdrop-blur-md border-b border-surface-border dark:border-dark-border md:px-8">
  <div class="flex flex-1 items-center justify-between">
    <!-- Search Bar -->
    <div class="flex w-full max-w-md">
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <span class="w-4 h-4 text-gray-400" />
        </div>
        <input
          type="text"
          placeholder="Search prompts, categories, tags..."
          class="block w-full pl-10 pr-3 py-2 border border-surface-border dark:border-dark-border rounded-xl bg-surface-card dark:bg-dark-card text-sm focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none transition-all"
        />
      </div>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center ml-4 space-x-4">
      <ThemeToggle />
      <button class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        <span class="w-5 h-5 text-gray-500" />
      </button>
      <div class="w-8 h-8 rounded-full bg-brand-primary flex items-center justify-center text-white font-bold">
        A
      </div>
    </div>
  </div>
</header>
