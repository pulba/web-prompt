---
const navItems = [
  { name: 'Home', href: '/admin' },
  { name: 'Prompts', href: '/admin/prompts' },
  { name: 'Add', href: '/admin/prompts/new' },
  { name: 'Tags', href: '/admin/tags' },
  { name: 'User', href: '/admin/settings' },
];
---

<nav class="md:hidden fixed bottom-0 left-0 right-0 bg-surface-card dark:bg-dark-card border-t border-surface-border dark:border-dark-border px-6 py-3 flex justify-between items-center z-50">
  {navItems.map((item) => (
    <a href={item.href} class="flex flex-col items-center text-gray-500 hover:text-brand-primary transition-colors">
      <div class={`w-6 h-6 ${item.name === 'Add' ? 'bg-brand-primary text-white rounded-full p-1 -mt-8 shadow-lg' : ''}`}>
        <!-- Icon Placeholder -->
      </div>
      <span class="text-[10px] mt-1 font-medium">{item.name}</span>
    </a>
  ))}
</nav>
