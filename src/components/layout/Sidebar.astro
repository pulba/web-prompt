---
const navItems = [
  { name: 'Dashboard', href: '/admin', icon: 'home' },
  { name: 'Prompts', href: '/admin/prompts', icon: 'terminal' },
  { name: 'Categories', href: '/admin/categories', icon: 'folder' },
  { name: 'Tags', href: '/admin/tags', icon: 'tag' },
  { name: 'Favorites', href: '/admin/favorites', icon: 'star' },
];
---

<div class="flex flex-col h-full bg-surface-card dark:bg-dark-card border-r border-surface-border dark:border-dark-border">
  <div class="flex items-center h-16 px-6 border-b border-surface-border dark:border-dark-border">
    <span class="text-xl font-bold text-brand-primary">Prompt Vault</span>
  </div>
  
  <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors hover:bg-gray-100 dark:hover:bg-gray-800 group"
      >
        <span class="w-5 h-5 mr-3 text-gray-400 group-hover:text-brand-primary" />
        {item.name}
      </a>
    ))}
  </nav>

  <div class="p-4 border-t border-surface-border dark:border-dark-border">
    <button class="flex items-center w-full px-4 py-2 text-sm font-medium text-red-600 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
      Logout
    </button>
  </div>
</div>
